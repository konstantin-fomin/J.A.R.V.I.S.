# Токен бота от @BotFather (обязательно)
TELEGRAM_BOT_TOKEN=

# Свой Telegram user id — бот будет отвечать только тебе (узнать: @userinfobot)
# Пусто = отвечает всем, кто найдёт бота
ALLOWED_USER_ID=

# Провайдер ответов: ollama | groq | gemini | openrouter | openai | anthropic
# Эмбеддинги для памяти всегда считает локальный Ollama (bge-m3)
LLM_PROVIDER=ollama

OLLAMA_MODEL=qwen2.5:7b

GROQ_API_KEY=
GROQ_MODEL=llama-3.1-70b-versatile

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro

OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/auto

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Необязательные переопределения (по умолчанию из config.py)
# Путь к памяти: по умолчанию ./bot-memory рядом с кодом (в Docker задаётся
# через docker-compose.yml). Локально на Windows можно указать Obsidian vault:
# OBSIDIAN_VAULT_PATH=./bot-memory
# LLM_MAX_TOKENS=4096
# OLLAMA_BASE_URL=http://localhost:11434
# Веб-интерфейс (порт и хост; 127.0.0.1 = только с этой машины)
# WEB_HOST=127.0.0.1
# WEB_PORT=8000
